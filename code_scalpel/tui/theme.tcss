/* Inspired by Claude Code color scheme */
$bg: #0f0f0f;
$bg-panel: #1c1c1c;
$fg: #d0d0d0;
$fg-dim: #585858;
$fg-muted: #3a3a3a;
$border: #2a2a2a;
$accent: #6bc8d4;
$thinking: #d4a050;
$success: #7fc090;
$error: #d97b6c;
$warning: #d4a050;
$diff-add: #7fc090;
$diff-add-bg: #16241a;
$diff-del: #d97b6c;
$diff-del-bg: #2a1818;
$line-num: #3a3a3a;
