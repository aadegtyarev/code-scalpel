/* color palette */
$bg: #0f0f0f;
$bg-panel: #1c1c1c;
$fg: #d0d0d0;
$fg-dim: #585858;
$fg-muted: #3a3a3a;
$border: #2a2a2a;
$accent: #00d7ff;
$thinking: #ff8700;
$success: #00ff87;
$error: #ff5555;
$warning: #ffb86c;
$diff-add: #50fa7b;
$diff-add-bg: #0a2a0a;
$diff-del: #ff5555;
$diff-del-bg: #2a0a0a;
$line-num: #3a3a3a;

Screen {
    background: $bg;
    color: $fg;
    layers: base;
}

#output {
    width: 1fr;
    height: 1fr;
    background: $bg;
    border: none;
    scrollbar-color: $fg-muted;
    scrollbar-background: $bg;
}

#input-bar {
    height: auto;
    min-height: 3;
    max-height: 12;
    background: $bg-panel;
    border-top: solid $border;
    border-bottom: solid $border;
    padding: 0 1;
    color: $fg;
}

#input-bar:focus-within {
    border-top: solid $accent;
}

#footer {
    height: 1;
    background: $bg-panel;
    color: $fg-dim;
    padding: 0 1;
}

.mode-prefix {
    color: $accent;
}

.status-idle {
    color: $fg-dim;
}

.status-thinking {
    color: $thinking;
}

.status-ok {
    color: $success;
}

.status-error {
    color: $error;
}
